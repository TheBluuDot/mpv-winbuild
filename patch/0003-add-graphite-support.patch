From ed6ed22d14bc74d812cc936cd0046b01b63bd5ab Mon Sep 17 00:00:00 2001
From: Github Actions <github-actions@github.com>
Date: Sat, 28 Feb 2026 00:00:00 +0000
Subject: [PATCH] Add statically linked graphite2 support

---
 packages/CMakeLists.txt              |  1 +
 packages/graphite2-0001-static.patch | 26 ++++++++++++++++++++++++
 packages/graphite2.cmake             | 24 ++++++++++++++++++++++
 packages/harfbuzz.cmake              |  2 ++
 4 files changed, 53 insertions(+)
 create mode 100644 packages/graphite2-0001-static.patch
 create mode 100644 packages/graphite2.cmake

diff --git a/packages/CMakeLists.txt b/packages/CMakeLists.txt
index 0e5c929..72b38f8 100644
--- a/packages/CMakeLists.txt
+++ b/packages/CMakeLists.txt
@@ -39,6 +39,7 @@ list(APPEND ep
     freetype2
     libudfread
     libbluray
+    graphite2
     harfbuzz
     libsoxr
     graphengine
diff --git a/packages/graphite2-0001-static.patch b/packages/graphite2-0001-static.patch
new file mode 100644
index 0000000..f2b3e8e
--- /dev/null
+++ b/packages/graphite2-0001-static.patch
@@ -0,0 +1,26 @@
+From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
+From: User <user@example.com>
+Date: Mon, 1 Jan 2025 00:00:00 +0000
+Subject: [PATCH] Build static library
+
+---
+ CMakeLists.txt     | 2 --
+ src/CMakeLists.txt | 2 +-
+ 2 files changed, 1 insertion(+), 3 deletions(-)
+
+diff --git a/CMakeLists.txt b/CMakeLists.txt
+--- a/CMakeLists.txt
++++ b/CMakeLists.txt
+@@ -74,5 +74,3 @@ endif()
+ 
+ add_subdirectory(src)
+-add_subdirectory(tests)
+-add_subdirectory(docs)
+diff --git a/src/CMakeLists.txt b/src/CMakeLists.txt
+--- a/src/CMakeLists.txt
++++ b/src/CMakeLists.txt
+@@ -38,7 +38,7 @@ endif()
+ 
+ nolto_requires(DirectMachine.cpp)
+ 
+-add_library(graphite2 SHARED
++add_library(graphite2 STATIC
+     ${GRAPHITE2_VM_MACHINE}
+     ${build_hdrs}
+     ${build_srcs}
diff --git a/packages/graphite2.cmake b/packages/graphite2.cmake
new file mode 100644
index 0000000..4bebf9b
--- /dev/null
+++ b/packages/graphite2.cmake
@@ -0,0 +1,24 @@
+ExternalProject_Add(graphite2
+    GIT_REPOSITORY https://github.com/silnrsi/graphite.git
+    SOURCE_DIR ${SOURCE_LOCATION}
+    GIT_CLONE_FLAGS "--filter=tree:0"
+    UPDATE_COMMAND ""
+    PATCH_COMMAND ${EXEC} git am --3way ${CMAKE_CURRENT_SOURCE_DIR}/graphite2-*.patch
+    CONFIGURE_COMMAND ${EXEC} CONF=1 cmake -H<SOURCE_DIR> -B<BINARY_DIR>
+        -G Ninja
+        -DCMAKE_BUILD_TYPE=Release
+        -DCMAKE_TOOLCHAIN_FILE=${TOOLCHAIN_FILE}
+        -DCMAKE_INSTALL_PREFIX=${MINGW_INSTALL_PREFIX}
+        -DCMAKE_FIND_ROOT_PATH=${MINGW_INSTALL_PREFIX}
+        -DBUILD_SHARED_LIBS=OFF
+        -DCMAKE_C_FLAGS='${CMAKE_C_FLAGS} -DGRAPHITE2_STATIC'
+        -DCMAKE_CXX_FLAGS='${CMAKE_CXX_FLAGS} -DGRAPHITE2_STATIC'
+    BUILD_COMMAND ${EXEC} ninja -C <BINARY_DIR>
+    INSTALL_COMMAND ${EXEC} ninja -C <BINARY_DIR> install
+            COMMAND ${EXEC} sed -i "s/Cflags:/Cflags: -DGRAPHITE2_STATIC/" ${MINGW_INSTALL_PREFIX}/lib/pkgconfig/graphite2.pc
+            COMMAND bash -c "echo 'Libs.private: -lstdc++' >> ${MINGW_INSTALL_PREFIX}/lib/pkgconfig/graphite2.pc"
+    LOG_DOWNLOAD 1 LOG_UPDATE 1 LOG_CONFIGURE 1 LOG_BUILD 1 LOG_INSTALL 1
+)
+
+force_rebuild_git(graphite2)
+cleanup(graphite2 install)
diff --git a/packages/harfbuzz.cmake b/packages/harfbuzz.cmake
index 53fb433..fc1c17d 100644
--- a/packages/harfbuzz.cmake
+++ b/packages/harfbuzz.cmake
@@ -2,6 +2,7 @@ ExternalProject_Add(harfbuzz
     DEPENDS
         freetype2
         libpng
+        graphite2
     GIT_REPOSITORY https://github.com/harfbuzz/harfbuzz.git
     SOURCE_DIR ${SOURCE_LOCATION}
     GIT_REMOTE_NAME origin
@@ -19,6 +20,7 @@ ExternalProject_Add(harfbuzz
         -Dtests=disabled
         -Ddocs=disabled
         -Dbenchmark=disabled
+        -Dgraphite2=enabled
     BUILD_COMMAND ${EXEC} ninja -C <BINARY_DIR>
     INSTALL_COMMAND ${EXEC} ninja -C <BINARY_DIR> install
     LOG_DOWNLOAD 1 LOG_UPDATE 1 LOG_CONFIGURE 1 LOG_BUILD 1 LOG_INSTALL 1
